---
layout: base
---

<main class="layout__main">
	<article class="content">
		<header class="content__header">
			<h1>{{ title }}</h1>
		</header>
		{{ content }}
	</article>
</main>
<nav class="layout__sidebar" aria-label="secondary">
	<ul>
		{% for component in collections.components %}
		<li>
			<a href="{{ component.url }}">{{ component.data.title }}</a>
		</li>
		{% endfor %}
	</ul>
</nav>
